# Domus-Quaesitor-koop — House Hunter Configuration
# Keep this file SECRET. Do NOT commit to git.

# --- Email ---
GMAIL_FROM=your.email@gmail.com
GMAIL_APP_PASSWORD=your-app-password
EMAIL_TO=mail@holie.be
EMAIL_CC=

# --- Search Criteria ---
TARGET_CITY=Geel
TARGET_POSTAL_CODE=2440
MIN_PRICE=400000
MAX_PRICE=700000
MIN_BEDROOMS=3
MIN_LIVING_SURFACE=115
MIN_LOT_SURFACE=450
SKIP_RENOVATION=true

# --- City filters (comma-separated) ---
# Override defaults from config.py if needed
CITY_ACCEPT_LIST=Geel, Lier, Ranst, Broechem, Emblem, Vremde, Wommelgem, Kessel
CITY_EXCLUDE_LIST=Koningshooikt, Oelegem, Nijlen, Bevel

# --- AI Scoring ---
# DeepSeek via OpenRouter (for text scoring)
DEEPSEEK_API_KEY=sk-your-deepseek-key
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Google Gemini API key (for photo scoring with vision)
GEMINI_API_KEY=your-gemini-api-key

# Optional: Enable/disable photo scoring
ENABLE_PHOTO_SCORING=true
